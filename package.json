{
	"name": "@kitschpatrol/tldraw-cli",
	"version": "6.0.2",
	"description": "A CLI tool and TypeScript library for exporting tldraw sketches to PNG or SVG images.",
	"keywords": [
		"tldraw",
		"tldr",
		"cli",
		"diagram",
		"drawing",
		"sketch",
		"export",
		"npm-package"
	],
	"homepage": "https://github.com/kitschpatrol/tldraw-cli",
	"bugs": "https://github.com/kitschpatrol/tldraw-cli/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kitschpatrol/tldraw-cli.git"
	},
	"license": "MIT",
	"author": {
		"name": "Eric Mika",
		"email": "eric@ericmika.com",
		"url": "https://ericmika.com"
	},
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/lib/index.d.ts",
			"import": "./dist/lib/index.js"
		}
	},
	"main": "./dist/lib/index.js",
	"module": "./dist/lib/index.js",
	"types": "./dist/lib/index.d.ts",
	"bin": {
		"tldraw": "dist/bin/cli.js",
		"tldraw-cli": "dist/bin/cli.js"
	},
	"files": [
		"dist/*"
	],
	"scripts": {
		"bench": "vitest bench --run --compare test/benchmarks/baseline.json",
		"bench:baseline": "vitest bench --run --outputJson test/benchmarks/baseline.json",
		"build": "pnpm build:tldraw && pnpm build:src",
		"build:src": "tsdown",
		"build:tldraw": "pnpm tldraw:copy-assets && vite build",
		"clean": "shx rm -f pnpm-lock.yaml && git clean -fdX -e !.claude/",
		"dev": "pnpm dev:tldraw",
		"dev:tldraw": "pnpm tldraw:copy-assets && vite",
		"fix": "ksc fix",
		"lint": "ksc lint",
		"preview": "pnpm preview:tldraw",
		"preview:tldraw": "vite preview",
		"release": "bumpp --commit 'Release: %s' && pnpm build && NPM_AUTH_TOKEN=$(op read 'op://Personal/npm/token') pnpm publish",
		"test": "vitest run",
		"test:watch": "pnpm build && vitest",
		"tldraw:copy-assets": "pnpm tsx ./scripts/copy-assets.ts"
	},
	"dependencies": {
		"@hono/node-server": "^2.0.10",
		"@sindresorhus/slugify": "^3.0.0",
		"@types/node": "~22.19.21",
		"cheerio": "^1.2.0",
		"get-port": "^7.2.0",
		"hono": "^4.12.30",
		"nanoid": "^6.0.0",
		"natural-orderby": "^5.0.0",
		"open": "^11.0.0",
		"path-type": "^6.0.0",
		"plur": "^6.0.0",
		"pretty-ms": "^9.3.0",
		"puppeteer": "^25.3.0",
		"uint8array-extras": "^1.5.0",
		"untildify": "^6.0.0",
		"yargs": "^18.0.0"
	},
	"devDependencies": {
		"@arethetypeswrong/core": "^0.18.5",
		"@blazediff/vitest": "^1.1.21",
		"@fontsource/inter": "^5.2.8",
		"@kitschpatrol/shared-config": "^8.4.0",
		"@tldraw/assets": "^5.2.5",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@types/yargs": "^17.0.35",
		"@vitejs/plugin-react": "^6.0.3",
		"bumpp": "^12.0.0",
		"esbuild": "^0.28.1",
		"mdat-plugin-cli-help": "^3.0.2",
		"node-addon-api": "^8.9.0",
		"node-gyp": "^13.0.1",
		"publint": "^0.3.21",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"rolldown": "^1.2.0",
		"safe-stable-stringify": "^2.5.0",
		"shx": "^0.4.0",
		"strip-ansi": "^7.2.0",
		"tldraw": "^5.2.5",
		"tsdown": "^0.22.8",
		"tsx": "^4.23.1",
		"typescript": "~6.0.3",
		"vite": "^8.1.4",
		"vitest": "^4.1.10"
	},
	"packageManager": "pnpm@11.13.1",
	"engines": {
		"node": ">=22.22.2"
	},
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": ">=24.16.0"
		}
	},
	"publishConfig": {
		"access": "public"
	}
}
